{
  "name": "sneakertail-online",
  "version": "0.1.0",
  "private": true,
  "description": "Microservices boilerplate for sneakertail.online.",
  "workspaces": [
    "services/*"
  ],
  "scripts": {
    "dev:frontend": "npm --workspace services/frontend run dev",
    "dev:catalog": "npm --workspace services/catalog-service run dev",
    "dev:cart": "npm --workspace services/cart-order-service run dev",
    "build": "npm --workspaces run build",
    "start:catalog": "npm --workspace services/catalog-service start",
    "start:cart": "npm --workspace services/cart-order-service start"
  },
  "engines": {
    "node": ">=20"
  }
}
