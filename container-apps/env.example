# Copy this file to .env or use the values directly with deploy.ps1.
# Do not commit real secrets.

RESOURCE_GROUP=RG-1
LOCATION=centralindia
CONTAINER_APPS_ENVIRONMENT=cae-sneakertail

# Optional. Use this when you create the Container Apps environment in a VNet subnet.
# The subnet must be dedicated to the Container Apps environment.
INFRASTRUCTURE_SUBNET_RESOURCE_ID=/subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.Network/virtualNetworks/<vnet-name>/subnets/<subnet-name>

POSTGRES_FQDN=<postgres-fqdn>
POSTGRES_DATABASE=sneakertail
POSTGRES_USER=pgadminuser

# URL-encode special characters in the password before building DATABASE_URL.
# Example: @ becomes %40
DATABASE_URL=postgres://pgadminuser:<url-encoded-password>@<postgres-fqdn>:5432/sneakertail?sslmode=require

FRONT_DOOR_PROFILE=afd-sneakertail
FRONT_DOOR_ENDPOINT=sneakertail
